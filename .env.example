# Firebase web config — copy this file to `.env.local` and fill in the values
# from your Firebase project (Project settings → General → Your apps → SDK setup).
# These VITE_ vars are inlined at build time. The Firebase web config is safe to
# expose in a client app; real protection comes from Firestore security rules.
#
# On Netlify, add the same keys under Site configuration → Environment variables.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# BoardGameGeek XML API token — used ONLY by the Netlify function (netlify/functions/bgg.js).
# NO "VITE_" prefix on purpose: that keeps it server-side and out of the client bundle.
# Local: put the real value in .env.local and run `netlify dev` (plain `vite` won't run functions).
# Netlify: add it under Site configuration → Environment variables. Do NOT add it to
# SECRETS_SCAN_OMIT_KEYS in netlify.toml — this one is genuinely secret.
BGG_API_TOKEN=
